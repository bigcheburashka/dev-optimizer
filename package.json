{
  "name": "dev-optimizer",
  "version": "0.1.0",
  "description": "Optimize Docker images, npm packages, and CI/CD pipelines in one CLI",
  "keywords": [
    "docker",
    "npm",
    "optimization",
    "ci-cd",
    "performance",
    "devtools"
  ],
  "author": "dev-optimizer",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dev-optimizer": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "depcheck": "^1.4.7",
    "ora": "^8.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "knip": "^5.86.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-optimizer/dev-optimizer"
  },
  "bugs": {
    "url": "https://github.com/dev-optimizer/dev-optimizer/issues"
  },
  "homepage": "https://github.com/dev-optimizer/dev-optimizer#readme"
}
